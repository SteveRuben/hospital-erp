{
  "name": "hospital-erp",
  "version": "1.0.0",
  "private": true,
  "description": "Hospital ERP - Application de gestion hospitalière",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "npm run build --workspace=@hospital-erp/backend",
    "start": "node packages/backend/dist/index.js",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "turbo": "^2.5.2",
    "typescript": "^5.7.2"
  }
}
