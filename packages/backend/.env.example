# Hospital ERP — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

PORT=5000
NODE_ENV=development

# PostgreSQL (Neon or local)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT Secret — MUST be a strong random string in production (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Redis (optional — for distributed session management)
# If not set, falls back to in-memory store (single instance only)
REDIS_URL=redis://localhost:6379

# Remita Payment API
REMITA_API_URL=https://api.remita.finance
REMITA_API_ID=your-api-id
REMITA_API_KEY=your-api-key
REMITA_USERNAME=your-username
REMITA_PASSWORD=your-password
REMITA_WEBHOOK_URL=https://your-domain.com/api/paiement-remita/webhook

# PHI Encryption Key — AES-256-GCM (32 bytes hex = 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHI_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
