# ============================================================================
#   Hospital ERP — Environment Variables
# ============================================================================
#   Copy to .env (`cp .env.example .env`) and fill in values.
#   .env is git-ignored. Never commit secrets.
#
#   For Railway / production deploys, set these via the Railway dashboard
#   (Settings → Variables) or `railway variables set KEY=value`.
#   See RAILWAY.md at the repo root.
# ============================================================================


# ─── REQUIRED ──────────────────────────────────────────────────────────────
#  Without these, the app either won't start or is insecure.
# ────────────────────────────────────────────────────────────────────────────

# Postgres connection string. Use Neon's pooled URL for production
# (`?pgbouncer=true&connection_limit=1` for Prisma, or set DB_POOL_MAX below).
DATABASE_URL=postgresql://user:password@host:5432/hospital_erp?sslmode=require

# JWT signing secret for the staff token (issued by /api/auth/login).
# MUST be a long random string in production. If left at the default value
# `hospital_secret_key_2024`, the server REFUSES TO START in production
# (see middleware/auth.ts:10).
#
# Generate one:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING

# Comma-separated allowed origins for CORS. Backend rejects all other origins.
# Production example: https://hospital-erp.up.railway.app
FRONTEND_URL=http://localhost:3000

# Set to `production` on Railway. Enables:
#   - HTTPS redirect (security.ts enforceHttps)
#   - Demo users (dr.martin, comptable1, labo1, reception1) NOT seeded
#   - Stricter error messages (no stack traces)
NODE_ENV=development


# ─── STRONGLY RECOMMENDED (security) ───────────────────────────────────────

# AES-256-GCM key for PHI encryption at rest (Lane B / OWASP A02).
# Without it, `numeroIdentite`, `contactUrgenceNom`, `contactUrgenceTelephone`
# are stored in plaintext. The encryption service runs in passthrough mode
# and the Sécurité posture page reports `encryption.enabled: false`.
#
# Generate one (must be exactly 64 hex chars = 32 bytes):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# After setting this in an environment that already has patient data, run:
#   cd packages/backend && npx tsx scripts/encrypt-patient-phi.ts --dry-run
#   cd packages/backend && npx tsx scripts/encrypt-patient-phi.ts
PHI_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS


# ─── OPTIONAL (have sensible defaults) ─────────────────────────────────────

# HTTP port. Railway sets this automatically; respect it.
PORT=5000

# Postgres connection pool size. Default 10. Neon free tier caps at ~5
# concurrent connections; raise only if you have a paid plan with headroom.
DB_POOL_MAX=10

# Redis for distributed session blacklist + activity tracking.
# Without it, sessions live in-memory (single-instance only — multi-replica
# deploys will see stale token blacklist state across instances).
# REDIS_URL=redis://default:password@host:6379


# ─── EMAIL (nodemailer) — OPTIONAL ─────────────────────────────────────────
#   If SMTP_USER is empty, email is a no-op (logged to console only).

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-account@example.com
# SMTP_PASS=your-app-password-or-smtp-password


# ─── SMS NOTIFICATIONS — OPTIONAL ──────────────────────────────────────────
#   Generic HTTP POST adapter that fits Africa's Talking, Twilio, etc.
#   If SMS_API_KEY is empty, SMS is a no-op (logged to console only).

# SMS_PROVIDER=africastalking
# SMS_API_KEY=your-api-key
# SMS_API_URL=https://api.africastalking.com/version1/messaging
# SMS_SENDER_ID=HospitalERP
