generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== AUTH =====

enum UserRole {
  admin
  medecin
  comptable
  laborantin
  reception
}

model User {
  id                  Int       @id @default(autoincrement())
  username            String    @unique @db.VarChar(100)
  password            String    @db.VarChar(255)
  role                UserRole
  nom                 String?   @db.VarChar(100)
  prenom              String?   @db.VarChar(100)
  telephone           String?   @db.VarChar(20)
  must_change_password Boolean  @default(true)
  mfaEnabled          Boolean   @default(false) @map("mfa_enabled")
  mfaSecret           String?   @map("mfa_secret") @db.VarChar(255)
  createdAt           DateTime  @default(now()) @map("created_at")

  notes               Note[]
  alertes             Alerte[]
  encounters          Encounter[] @relation("provider")
  observations        Observation[] @relation("obs_provider")
  orders              Order[]   @relation("orderer")
  auditLogs           AuditLog[]

  @@map("users")
}

// ===== PATIENTS =====

enum Sexe {
  M
  F
  autre
}

enum StatutMatrimonial {
  celibataire
  marie
  divorce
  veuf
}

enum GroupeSanguin {
  Aplus  @map("A+")
  Amoins @map("A-")
  Bplus  @map("B+")
  Bmoins @map("B-")
  ABplus @map("AB+")
  ABmoins @map("AB-")
  Oplus  @map("O+")
  Omoins @map("O-")
}

model Patient {
  id                      Int       @id @default(autoincrement())
  nom                     String    @db.VarChar(100)
  prenom                  String    @db.VarChar(100)
  deuxiemePrenom          String?   @map("deuxieme_prenom") @db.VarChar(100)
  sexe                    Sexe?
  dateNaissance           DateTime? @map("date_naissance") @db.Date
  ageEstime               Int?      @map("age_estime")
  lieuNaissance           String?   @map("lieu_naissance") @db.VarChar(100)
  nationalite             String?   @db.VarChar(100)
  numeroIdentite          String?   @map("numero_identite") @db.VarChar(50)
  statutMatrimonial       StatutMatrimonial? @map("statut_matrimonial")
  groupeSanguin           GroupeSanguin?     @map("groupe_sanguin")
  pays                    String?   @db.VarChar(100)
  province                String?   @db.VarChar(100)
  ville                   String?   @db.VarChar(100)
  commune                 String?   @db.VarChar(100)
  quartier                String?   @db.VarChar(100)
  adresse                 String?
  profession              String?   @db.VarChar(100)
  telephone               String?   @db.VarChar(20)
  email                   String?   @db.VarChar(150)
  contactUrgenceNom       String?   @map("contact_urgence_nom") @db.VarChar(100)
  contactUrgenceRelation  String?   @map("contact_urgence_relation") @db.VarChar(50)
  contactUrgenceTelephone String?   @map("contact_urgence_telephone") @db.VarChar(20)
  photoUrl                String?   @map("photo_url")
  archived                Boolean   @default(false)
  referenceId             String?   @unique @map("reference_id") @db.VarChar(30)
  createdAt               DateTime  @default(now()) @map("created_at")

  consultations   Consultation[]
  recettes        Recette[]
  examens         Examen[]
  rendezVous      RendezVous[]
  vitaux          Vital[]
  allergies       Allergie[]
  pathologies     Pathologie[]
  prescriptions   Prescription[]
  ordonnances     Ordonnance[]
  vaccinations    Vaccination[]
  notes           Note[]
  alertes         Alerte[]
  encounters      Encounter[]
  observations    Observation[]
  orders          Order[]
  visites         Visite[]
  hospitalisations Hospitalisation[]

  @@map("patients")
}

// ===== MEDECINS =====

model Medecin {
  id          Int       @id @default(autoincrement())
  nom         String    @db.VarChar(100)
  prenom      String    @db.VarChar(100)
  specialite  String?   @db.VarChar(100)
  telephone   String?   @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")

  consultations Consultation[]
  rendezVous    RendezVous[]
  vitaux        Vital[]
  prescriptions Prescription[]
  ordonnances   Ordonnance[]
  vaccinations  Vaccination[]
  hospitalisations Hospitalisation[]

  @@map("medecins")
}

// ===== SERVICES =====

model Service {
  id          Int       @id @default(autoincrement())
  nom         String    @db.VarChar(200)
  description String?
  parentId    Int?      @map("parent_id")
  prix        Decimal?  @default(0) @db.Decimal(12, 2)
  poids       Int?      @default(0)
  code        String?   @db.VarChar(50)
  actif       Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")

  parent        Service?  @relation("ServiceHierarchy", fields: [parentId], references: [id])
  children      Service[] @relation("ServiceHierarchy")
  consultations Consultation[]
  recettes      Recette[]
  rendezVous    RendezVous[]
  encounters    Encounter[]
  visites       Visite[]
  hospitalisations Hospitalisation[]

  @@map("services")
}

// ===== CONSULTATIONS =====

model Consultation {
  id               Int       @id @default(autoincrement())
  reference        String?   @unique @db.VarChar(20)
  patientId        Int       @map("patient_id")
  medecinId        Int?      @map("medecin_id")
  serviceId        Int?      @map("service_id")
  dateConsultation DateTime  @default(now()) @map("date_consultation")
  diagnostic       String?
  traitement       String?
  notes            String?
  statut           String?   @default("en_cours") @db.VarChar(50)
  motif            String?
  gravite          String?   @db.VarChar(20)

  patient  Patient  @relation(fields: [patientId], references: [id])
  medecin  Medecin? @relation(fields: [medecinId], references: [id])
  service  Service? @relation(fields: [serviceId], references: [id])

  @@map("consultations")
}

// ===== CONCEPTS (OpenMRS) =====

enum ConceptDatatype {
  numeric
  coded
  text
  date
  boolean
  datetime
  document
}

enum ConceptClasse {
  diagnostic
  symptome
  test
  medicament
  procedure
  finding
  question
  reponse
  misc
}

model Concept {
  id          Int              @id @default(autoincrement())
  nom         String           @db.VarChar(200)
  code        String?          @unique @db.VarChar(50)
  datatype    ConceptDatatype
  classe      ConceptClasse
  description String?
  unite       String?          @db.VarChar(50)
  valeurMin   Decimal?         @map("valeur_min") @db.Decimal(10, 2)
  valeurMax   Decimal?         @map("valeur_max") @db.Decimal(10, 2)
  actif       Boolean          @default(true)
  createdAt   DateTime         @default(now()) @map("created_at")

  observations    Observation[] @relation("obs_concept")
  observationsCoded Observation[] @relation("obs_coded")
  orders          Order[]

  @@map("concepts")
}

// ===== ENCOUNTERS =====

model EncounterType {
  id          Int       @id @default(autoincrement())
  nom         String    @db.VarChar(100)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")

  encounters Encounter[]

  @@map("encounter_types")
}

model Encounter {
  id              Int       @id @default(autoincrement())
  reference       String?   @unique @db.VarChar(20)
  patientId       Int       @map("patient_id")
  encounterTypeId Int       @map("encounter_type_id")
  visiteId        Int?      @map("visite_id")
  providerId      Int?      @map("provider_id")
  serviceId       Int?      @map("service_id")
  dateEncounter   DateTime  @default(now()) @map("date_encounter")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  patient       Patient       @relation(fields: [patientId], references: [id])
  encounterType EncounterType @relation(fields: [encounterTypeId], references: [id])
  visite        Visite?       @relation(fields: [visiteId], references: [id])
  provider      User?         @relation("provider", fields: [providerId], references: [id])
  service       Service?      @relation(fields: [serviceId], references: [id])
  observations  Observation[]
  orders        Order[]

  @@map("encounters")
}

model Observation {
  id              Int       @id @default(autoincrement())
  encounterId     Int       @map("encounter_id")
  patientId       Int       @map("patient_id")
  conceptId       Int       @map("concept_id")
  valeurNumerique Decimal?  @map("valeur_numerique") @db.Decimal(12, 4)
  valeurTexte     String?   @map("valeur_texte")
  valeurDate      DateTime? @map("valeur_date")
  valeurCoded     Int?      @map("valeur_coded")
  valeurBoolean   Boolean?  @map("valeur_boolean")
  commentaire     String?
  providerId      Int?      @map("provider_id")
  dateObs         DateTime  @default(now()) @map("date_obs")
  voided          Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at")

  encounter    Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  patient      Patient   @relation(fields: [patientId], references: [id])
  concept      Concept   @relation("obs_concept", fields: [conceptId], references: [id])
  codedConcept Concept?  @relation("obs_coded", fields: [valeurCoded], references: [id])
  provider     User?     @relation("obs_provider", fields: [providerId], references: [id])

  @@map("observations")
}

// ===== ORDERS =====

model Order {
  id           Int       @id @default(autoincrement())
  reference    String?   @unique @db.VarChar(20)
  patientId    Int       @map("patient_id")
  encounterId  Int?      @map("encounter_id")
  conceptId    Int?      @map("concept_id")
  typeOrder    String    @map("type_order") @db.VarChar(30)
  ordererId    Int?      @map("orderer_id")
  urgence      String    @default("routine") @db.VarChar(20)
  instructions String?
  dateDebut    DateTime  @default(now()) @map("date_debut")
  dateFin      DateTime? @map("date_fin")
  statut       String    @default("actif") @db.VarChar(30)
  dosage       String?   @db.VarChar(100)
  frequence    String?   @db.VarChar(100)
  duree        String?   @db.VarChar(100)
  voie         String?   @db.VarChar(50)
  quantite     Int?
  resultat     String?
  dateResultat DateTime? @map("date_resultat")
  createdAt    DateTime  @default(now()) @map("created_at")

  patient   Patient    @relation(fields: [patientId], references: [id])
  encounter Encounter? @relation(fields: [encounterId], references: [id])
  concept   Concept?   @relation(fields: [conceptId], references: [id])
  orderer   User?      @relation("orderer", fields: [ordererId], references: [id])

  @@map("orders")
}

// ===== Simplified models for remaining tables =====

model Recette {
  id              Int       @id @default(autoincrement())
  patientId       Int?      @map("patient_id")
  serviceId       Int?      @map("service_id")
  typeActe        String    @map("type_acte") @db.VarChar(100)
  montant         Decimal   @db.Decimal(12, 2)
  modePaiement    String?   @map("mode_paiement") @db.VarChar(50)
  dateRecette     DateTime  @default(now()) @map("date_recette") @db.Date
  description     String?
  annulee         Boolean?  @default(false)
  dateAnnulation  DateTime? @map("date_annulation")
  annuleePar      Int?      @map("annulee_par")
  createdAt       DateTime  @default(now()) @map("created_at")
  patient         Patient?  @relation(fields: [patientId], references: [id])
  service         Service?  @relation(fields: [serviceId], references: [id])
  @@map("recettes")
}

model Examen {
  id          Int      @id @default(autoincrement())
  reference   String?  @unique @db.VarChar(20)
  patientId   Int      @map("patient_id")
  typeExamen  String   @map("type_examen") @db.VarChar(100)
  resultat    String?
  dateExamen  DateTime @default(now()) @map("date_examen") @db.Date
  montant     Decimal? @db.Decimal(10, 2)
  statut      String?  @default("demande") @db.VarChar(50)
  demandeurId Int?     @map("demandeur_id")
  createdAt   DateTime @default(now()) @map("created_at")
  patient     Patient  @relation(fields: [patientId], references: [id])
  @@map("examens")
}

model RendezVous {
  id        Int      @id @default(autoincrement())
  patientId Int      @map("patient_id")
  medecinId Int?     @map("medecin_id")
  serviceId Int?     @map("service_id")
  dateRdv   DateTime @map("date_rdv")
  motif     String?
  statut    String   @default("planifie") @db.VarChar(50)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  patient   Patient  @relation(fields: [patientId], references: [id])
  medecin   Medecin? @relation(fields: [medecinId], references: [id])
  service   Service? @relation(fields: [serviceId], references: [id])
  @@map("rendez_vous")
}

model Vital {
  id                   Int      @id @default(autoincrement())
  patientId            Int      @map("patient_id")
  medecinId            Int?     @map("medecin_id")
  temperature          Decimal? @db.Decimal(4, 1)
  tensionSystolique    Int?     @map("tension_systolique")
  tensionDiastolique   Int?     @map("tension_diastolique")
  pouls                Int?
  frequenceRespiratoire Int?    @map("frequence_respiratoire")
  saturationO2         Int?     @map("saturation_o2")
  poids                Decimal? @db.Decimal(5, 1)
  taille               Decimal? @db.Decimal(5, 1)
  glycemie             Decimal? @db.Decimal(5, 2)
  notes                String?
  dateMesure           DateTime @default(now()) @map("date_mesure")
  createdAt            DateTime @default(now()) @map("created_at")
  patient              Patient  @relation(fields: [patientId], references: [id])
  medecin              Medecin? @relation(fields: [medecinId], references: [id])
  @@map("vitaux")
}

model Allergie {
  id           Int      @id @default(autoincrement())
  patientId    Int      @map("patient_id")
  allergene    String   @db.VarChar(200)
  typeAllergie String?  @map("type_allergie") @db.VarChar(50)
  severite     String?  @db.VarChar(20)
  reaction     String?
  dateDebut    DateTime? @map("date_debut") @db.Date
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  patient      Patient  @relation(fields: [patientId], references: [id])
  @@map("allergies")
}

model Pathologie {
  id        Int       @id @default(autoincrement())
  patientId Int       @map("patient_id")
  nom       String    @db.VarChar(200)
  codeCim   String?   @map("code_cim") @db.VarChar(20)
  statut    String    @default("active") @db.VarChar(50)
  dateDebut DateTime? @map("date_debut") @db.Date
  dateFin   DateTime? @map("date_fin") @db.Date
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  patient   Patient   @relation(fields: [patientId], references: [id])
  @@map("pathologies")
}

model Prescription {
  id             Int       @id @default(autoincrement())
  patientId      Int       @map("patient_id")
  medecinId      Int?      @map("medecin_id")
  consultationId Int?      @map("consultation_id")
  medicament     String    @db.VarChar(200)
  dosage         String?   @db.VarChar(100)
  frequence      String?   @db.VarChar(100)
  duree          String?   @db.VarChar(100)
  voie           String?   @db.VarChar(50)
  instructions   String?
  statut         String    @default("active") @db.VarChar(50)
  dateDebut      DateTime  @default(now()) @map("date_debut") @db.Date
  dateFin        DateTime? @map("date_fin") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at")
  patient        Patient   @relation(fields: [patientId], references: [id])
  medecin        Medecin?  @relation(fields: [medecinId], references: [id])
  @@map("prescriptions")
}

model Ordonnance {
  id             Int      @id @default(autoincrement())
  patientId      Int      @map("patient_id")
  medecinId      Int?     @map("medecin_id")
  consultationId Int?     @map("consultation_id")
  dateOrdonnance DateTime @default(now()) @map("date_ordonnance") @db.Date
  notes          String?
  statut         String   @default("emise") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at")
  patient        Patient  @relation(fields: [patientId], references: [id])
  medecin        Medecin? @relation(fields: [medecinId], references: [id])
  @@map("ordonnances")
}

model Vaccination {
  id              Int       @id @default(autoincrement())
  patientId       Int       @map("patient_id")
  medecinId       Int?      @map("medecin_id")
  vaccin          String    @db.VarChar(200)
  lot             String?   @db.VarChar(100)
  dose            String?   @db.VarChar(50)
  siteInjection   String?   @map("site_injection") @db.VarChar(100)
  dateVaccination DateTime  @default(now()) @map("date_vaccination") @db.Date
  dateRappel      DateTime? @map("date_rappel") @db.Date
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  patient         Patient   @relation(fields: [patientId], references: [id])
  medecin         Medecin?  @relation(fields: [medecinId], references: [id])
  @@map("vaccinations")
}

model Note {
  id        Int      @id @default(autoincrement())
  patientId Int      @map("patient_id")
  auteurId  Int      @map("auteur_id")
  titre     String?  @db.VarChar(200)
  contenu   String
  typeNote  String   @default("general") @map("type_note") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  patient   Patient  @relation(fields: [patientId], references: [id])
  auteur    User     @relation(fields: [auteurId], references: [id])
  @@map("notes")
}

model Alerte {
  id         Int      @id @default(autoincrement())
  patientId  Int      @map("patient_id")
  typeAlerte String?  @map("type_alerte") @db.VarChar(50)
  message    String
  severite   String   @default("info") @db.VarChar(20)
  active     Boolean  @default(true)
  createdBy  Int?     @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  patient    Patient  @relation(fields: [patientId], references: [id])
  creator    User?    @relation(fields: [createdBy], references: [id])
  @@map("alertes")
}

model Visite {
  id         Int       @id @default(autoincrement())
  patientId  Int       @map("patient_id")
  serviceId  Int?      @map("service_id")
  typeVisite String    @default("ambulatoire") @map("type_visite") @db.VarChar(50)
  dateDebut  DateTime  @default(now()) @map("date_debut")
  dateFin    DateTime? @map("date_fin")
  statut     String    @default("active") @db.VarChar(50)
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  patient    Patient   @relation(fields: [patientId], references: [id])
  service    Service?  @relation(fields: [serviceId], references: [id])
  encounters Encounter[]
  @@map("visites")
}

model Hospitalisation {
  id            Int       @id @default(autoincrement())
  patientId     Int       @map("patient_id")
  litId         Int?      @map("lit_id")
  medecinId     Int?      @map("medecin_id")
  serviceId     Int?      @map("service_id")
  dateAdmission DateTime  @default(now()) @map("date_admission")
  dateSortie    DateTime? @map("date_sortie")
  motif         String?
  statut        String    @default("active") @db.VarChar(50)
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  patient       Patient   @relation(fields: [patientId], references: [id])
  medecin       Medecin?  @relation(fields: [medecinId], references: [id])
  service       Service?  @relation(fields: [serviceId], references: [id])
  @@map("hospitalisations")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String?  @db.VarChar(100)
  tableName String?  @map("table_name") @db.VarChar(50)
  recordId  Int?     @map("record_id")
  details   String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])
  @@map("audit_log")
}

// ===== FINANCES =====

model Depense {
  id             Int       @id @default(autoincrement())
  typeDepense    String    @map("type_depense") @db.VarChar(100)
  nature         String?   @db.VarChar(100)
  montant        Decimal   @db.Decimal(12, 2)
  fournisseur    String?   @db.VarChar(100)
  description    String?
  dateDepense    DateTime  @default(now()) @map("date_depense") @db.Date
  annulee        Boolean?  @default(false)
  dateAnnulation DateTime? @map("date_annulation")
  annuleePar     Int?      @map("annulee_par")
  createdAt      DateTime  @default(now()) @map("created_at")
  @@map("depenses")
}

model Document {
  id           Int      @id @default(autoincrement())
  patientId    Int?     @map("patient_id")
  typeDocument String?  @map("type_document") @db.VarChar(50)
  fichierUrl   String?  @map("fichier_url")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")
  @@map("documents")
}

model Formulaire {
  id          Int      @id @default(autoincrement())
  nom         String   @db.VarChar(200)
  description String?
  schemaJson  String   @map("schema_json")
  serviceId   Int?     @map("service_id")
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("formulaires")
}

model FormulaireReponse {
  id            Int      @id @default(autoincrement())
  formulaireId  Int?     @map("formulaire_id")
  patientId     Int?     @map("patient_id")
  rempliPar     Int?     @map("rempli_par")
  donneesJson   String   @map("donnees_json")
  createdAt     DateTime @default(now()) @map("created_at")
  @@map("formulaire_reponses")
}

model FileAttente {
  id                 Int       @id @default(autoincrement())
  patientId          Int?      @map("patient_id")
  serviceId          Int?      @map("service_id")
  priorite           String    @default("normal") @db.VarChar(20)
  statut             String    @default("en_attente") @db.VarChar(50)
  numeroOrdre        Int?      @map("numero_ordre")
  dateArrivee        DateTime  @default(now()) @map("date_arrivee")
  datePriseEnCharge  DateTime? @map("date_prise_en_charge")
  notes              String?
  @@map("file_attente")
}

model ListePatient {
  id          Int      @id @default(autoincrement())
  nom         String   @db.VarChar(200)
  description String?
  createdBy   Int?     @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("listes_patients")
}

model ListePatientMembre {
  id        Int      @id @default(autoincrement())
  listeId   Int?     @map("liste_id")
  patientId Int?     @map("patient_id")
  addedAt   DateTime @default(now()) @map("added_at")
  @@unique([listeId, patientId])
  @@map("liste_patient_membres")
}

model Pavillon {
  id          Int      @id @default(autoincrement())
  nom         String   @db.VarChar(100)
  etage       String?  @db.VarChar(50)
  serviceId   Int?     @map("service_id")
  capacite    Int?     @default(0)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("pavillons")
}

model Lit {
  id         Int      @id @default(autoincrement())
  pavillonId Int?     @map("pavillon_id")
  numero     String   @db.VarChar(20)
  typeLit    String   @default("standard") @map("type_lit") @db.VarChar(50)
  statut     String   @default("disponible") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")
  @@map("lits")
}

model Programme {
  id             Int      @id @default(autoincrement())
  nom            String   @db.VarChar(200)
  description    String?
  typeProgramme  String?  @map("type_programme") @db.VarChar(100)
  actif          Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  @@map("programmes")
}

model ProgrammePatient {
  id              Int       @id @default(autoincrement())
  programmeId     Int?      @map("programme_id")
  patientId       Int?      @map("patient_id")
  dateInscription DateTime  @default(now()) @map("date_inscription") @db.Date
  dateSortie      DateTime? @map("date_sortie") @db.Date
  statut          String    @default("actif") @db.VarChar(50)
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  @@map("programme_patients")
}

model Tarif {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  libelle   String   @db.VarChar(200)
  categorie String   @db.VarChar(100)
  montant   Decimal  @db.Decimal(12, 2)
  serviceId Int?     @map("service_id")
  actif     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  @@map("tarifs")
}

model Facture {
  id           Int      @id @default(autoincrement())
  numero       String   @unique @db.VarChar(50)
  patientId    Int?     @map("patient_id")
  dateFacture  DateTime @default(now()) @map("date_facture") @db.Date
  montantTotal Decimal  @default(0) @map("montant_total") @db.Decimal(12, 2)
  montantPaye  Decimal  @default(0) @map("montant_paye") @db.Decimal(12, 2)
  statut       String   @default("en_attente") @db.VarChar(50)
  notes        String?
  createdBy    Int?     @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  @@map("factures")
}

model FactureLigne {
  id            Int      @id @default(autoincrement())
  factureId     Int?     @map("facture_id")
  tarifId       Int?     @map("tarif_id")
  libelle       String   @db.VarChar(200)
  quantite      Int      @default(1)
  prixUnitaire  Decimal  @map("prix_unitaire") @db.Decimal(12, 2)
  montant       Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  @@map("facture_lignes")
}

model Paiement {
  id           Int      @id @default(autoincrement())
  factureId    Int?     @map("facture_id")
  montant      Decimal  @db.Decimal(12, 2)
  modePaiement String?  @map("mode_paiement") @db.VarChar(50)
  reference    String?  @db.VarChar(100)
  datePaiement DateTime @default(now()) @map("date_paiement")
  recuPar      Int?     @map("recu_par")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  @@map("paiements")
}

// ===== ADMIN / RBAC =====

model Habilitation {
  id     Int     @id @default(autoincrement())
  role   String  @db.VarChar(50)
  module String  @db.VarChar(100)
  acces  Boolean @default(true)
  @@unique([role, module])
  @@map("habilitations")
}

model MenuConfig {
  id          Int     @id @default(autoincrement())
  groupe      String  @db.VarChar(100)
  groupeOrdre Int     @default(0) @map("groupe_ordre")
  module      String  @db.VarChar(100)
  label       String  @db.VarChar(100)
  icon        String  @db.VarChar(50)
  path        String  @db.VarChar(200)
  ordre       Int     @default(0)
  actif       Boolean @default(true)
  @@map("menu_config")
}

// ===== PHARMACIE =====

model Medicament {
  id             Int      @id @default(autoincrement())
  nom            String   @db.VarChar(200)
  dci            String?  @db.VarChar(200)
  forme          String?  @db.VarChar(50)
  dosageStandard String?  @map("dosage_standard") @db.VarChar(100)
  codeBarre      String?  @map("code_barre") @db.VarChar(50)
  categorie      String?  @db.VarChar(100)
  prixUnitaire   Decimal? @map("prix_unitaire") @db.Decimal(12, 2)
  actif          Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  @@map("medicaments")
}

model Stock {
  id             Int       @id @default(autoincrement())
  medicamentId   Int?      @map("medicament_id")
  lot            String?   @db.VarChar(100)
  dateExpiration DateTime? @map("date_expiration") @db.Date
  quantite       Int       @default(0)
  quantiteMin    Int       @default(10) @map("quantite_min")
  prixAchat      Decimal?  @map("prix_achat") @db.Decimal(12, 2)
  fournisseur    String?   @db.VarChar(200)
  dateEntree     DateTime  @default(now()) @map("date_entree") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at")
  @@map("stock")
}

model StockMouvement {
  id            Int      @id @default(autoincrement())
  medicamentId  Int?     @map("medicament_id")
  typeMouvement String   @map("type_mouvement") @db.VarChar(20)
  quantite      Int
  lot           String?  @db.VarChar(100)
  motif         String?
  userId        Int?     @map("user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  @@map("stock_mouvements")
}

model Dispensation {
  id               Int      @id @default(autoincrement())
  patientId        Int?     @map("patient_id")
  prescriptionId   Int?     @map("prescription_id")
  medicamentId     Int?     @map("medicament_id")
  quantiteDelivree Int?     @map("quantite_delivree")
  dispenseurId     Int?     @map("dispenseur_id")
  dateDispensation DateTime @default(now()) @map("date_dispensation")
  notes            String?
  @@map("dispensations")
}

// ===== FACILITIES / MULTI-SITE =====

model Facility {
  id           Int      @id @default(autoincrement())
  nom          String   @db.VarChar(200)
  code         String?  @unique @db.VarChar(50)
  typeFacility String?  @map("type_facility") @db.VarChar(50)
  adresse      String?
  ville        String?  @db.VarChar(100)
  telephone    String?  @db.VarChar(20)
  email        String?  @db.VarChar(150)
  actif        Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  @@map("facilities")
}

// ===== PLANNING =====

model PlanningMedecin {
  id            Int      @id @default(autoincrement())
  medecinId     Int?     @map("medecin_id")
  serviceId     Int?     @map("service_id")
  jourSemaine   Int      @map("jour_semaine")
  heureDebut    DateTime @map("heure_debut") @db.Time
  heureFin      DateTime @map("heure_fin") @db.Time
  dureeCreneau  Int      @default(30) @map("duree_creneau")
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  @@map("planning_medecins")
}

model PlanningBlocage {
  id        Int      @id @default(autoincrement())
  medecinId Int?     @map("medecin_id")
  dateDebut DateTime @map("date_debut")
  dateFin   DateTime @map("date_fin")
  motif     String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  @@map("planning_blocages")
}

// ===== IMAGERIE =====

model Imagerie {
  id           Int      @id @default(autoincrement())
  patientId    Int?     @map("patient_id")
  typeExamen   String?  @map("type_examen") @db.VarChar(100)
  description  String?
  fichierUrl   String?  @map("fichier_url")
  fichierNom   String?  @map("fichier_nom") @db.VarChar(200)
  fichierType  String?  @map("fichier_type") @db.VarChar(50)
  dateExamen   DateTime @default(now()) @map("date_examen") @db.Date
  medecinId    Int?     @map("medecin_id")
  createdAt    DateTime @default(now()) @map("created_at")
  @@map("imagerie")
}

// ===== CONCEPT EXTENSIONS =====

model ConceptNom {
  id        Int    @id @default(autoincrement())
  conceptId Int?   @map("concept_id")
  nom       String @db.VarChar(200)
  langue    String @default("fr") @db.VarChar(10)
  typeNom   String @default("complet") @map("type_nom") @db.VarChar(20)
  @@unique([conceptId, nom, langue])
  @@map("concept_noms")
}

model ConceptReponse {
  id               Int  @id @default(autoincrement())
  conceptId        Int? @map("concept_id")
  reponseConceptId Int? @map("reponse_concept_id")
  ordre            Int  @default(0)
  @@map("concept_reponses")
}

model ConceptMapping {
  id           Int    @id @default(autoincrement())
  conceptId    Int?   @map("concept_id")
  source       String @db.VarChar(50)
  codeExterne  String @map("code_externe") @db.VarChar(50)
  @@unique([conceptId, source, codeExterne])
  @@map("concept_mappings")
}

// ===== NOTIFICATIONS =====

model NotificationLog {
  id        Int      @id @default(autoincrement())
  patientId Int?     @map("patient_id")
  channel   String   @db.VarChar(20)
  subject   String?  @db.VarChar(200)
  message   String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  @@map("notifications_log")
}

// ===== PATIENT ATTRIBUTIONS / WEBHOOKS =====

model PatientAttribution {
  id              Int      @id @default(autoincrement())
  patientId       Int?     @map("patient_id")
  medecinUserId   Int?     @map("medecin_user_id")
  dateAttribution DateTime @default(now()) @map("date_attribution")
  actif           Boolean  @default(true)
  @@unique([patientId, medecinUserId])
  @@map("patient_attributions")
}

model WebhookEvent {
  id          Int      @id @default(autoincrement())
  eventId     String   @unique @map("event_id") @db.VarChar(100)
  source      String   @db.VarChar(50)
  payload     String?
  processedAt DateTime @default(now()) @map("processed_at")
  @@map("webhook_events")
}

model Setting {
  id          Int      @id @default(autoincrement())
  cle         String   @unique @db.VarChar(100)
  valeur      String
  description String?
  categorie   String?  @default("general") @db.VarChar(50)
  updatedAt   DateTime @default(now()) @map("updated_at")
  @@map("settings")
}

model ReferenceList {
  id         Int      @id @default(autoincrement())
  categorie  String   @db.VarChar(50)
  code       String   @db.VarChar(100)
  libelle    String   @db.VarChar(200)
  actif      Boolean  @default(true)
  parDefaut  Boolean  @default(false) @map("par_defaut")
  ordre      Int      @default(0)
  parentCode String?  @map("parent_code") @db.VarChar(100)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  @@unique([categorie, code])
  @@map("reference_lists")
}